+    fn scroll_copy_mode_line(
+        &mut self,
+        terminal_runtimes: &TerminalRuntimeRegistry,
+        direction: i16,
+    ) {
+        let Some(copy_mode) = self.copy_mode.as_ref() else {
+            return;
+        };
+        let pane_id = copy_mode.pane_id;
+        let mut cursor_row = copy_mode.cursor_row;
+        let Some(info) = self.pane_info_by_id(pane_id).cloned() else {
+            self.exit_copy_mode(terminal_runtimes, false);
+            return;
+        };
+        if let Some(metrics) = self.pane_scroll_metrics(terminal_runtimes, pane_id) {
+            if direction < 0 {
+                if metrics.offset_from_bottom >= metrics.max_offset_from_bottom {
+                    return;
+                }
+                self.set_pane_scroll_offset(
+                    terminal_runtimes,
+                    pane_id,
+                    metrics.offset_from_bottom.saturating_add(1),
+                );
+                cursor_row = cursor_row
+                    .saturating_add(1)
+                    .min(info.inner_rect.height.saturating_sub(1));
+            } else {
+                if metrics.offset_from_bottom == 0 {
+                    return;
+                }
+                self.set_pane_scroll_offset(
+                    terminal_runtimes,
+                    pane_id,
+                    metrics.offset_from_bottom - 1,
+                );
+                cursor_row = cursor_row.saturating_sub(1);
+            }
+        } else if direction < 0 {
+            self.scroll_pane_up(terminal_runtimes, pane_id, 1);
+        } else {
+            self.scroll_pane_down(terminal_runtimes, pane_id, 1);
+        }
+        if let Some(copy_mode) = self.copy_mode.as_mut() {
+            copy_mode.cursor_row = cursor_row;
+        }
+        self.sync_copy_mode_selection(terminal_runtimes);
+    }
